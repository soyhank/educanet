generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum RolUsuario {
  TRABAJADOR
  ADMIN
  RRHH
}

enum NivelCurso {
  BASICO
  INTERMEDIO
  AVANZADO
}

enum TipoLeccion {
  VIDEO
  QUIZ
  LECTURA
}

enum TipoPregunta {
  UNICA
  MULTIPLE
}

enum TipoRecurso {
  PDF
  ENLACE
  DESCARGA
}

enum RazonPuntos {
  COMPLETAR_LECCION
  APROBAR_QUIZ
  COMPLETAR_CURSO
  RACHA_DIAS
  COMPLETAR_RUTA
  AJUSTE_ADMIN
  LOGRO_OBJETIVO
  SUBIDA_NIVEL
  LIKE_RECIBIDO
}

enum EstadoReporte {
  PENDIENTE
  APROBADO
  DESESTIMADO
}

enum TipoMetaKpi {
  ABSOLUTA
  RELATIVA_BASELINE
  BINARIA
}

enum FrecuenciaKpi {
  SEMANAL
  MENSUAL
}

enum EstadoKpiInstancia {
  PENDIENTE
  EN_REVISION
  APROBADO
  RECHAZADO
  NO_APLICA
}

enum TipoRango {
  BRONCE
  PLATA
  ORO
  DIAMANTE
}

enum TipoEventoGamificacion {
  LECCION_COMPLETADA
  CURSO_COMPLETADO
  QUIZ_APROBADO
  QUIZ_PERFECTO
  RACHA_INCREMENTADA
  BADGE_OBTENIDO
  SUBIDA_NIVEL
  LIKE_RECIBIDO
  KPI_MES_CUMPLIDO
  KPIS_MES_TOTAL
  KPI_HITO_APROBADO
  COMPROMISO_CUMPLIDO
  RECONOCIMIENTO_RECIBIDO
  MISION_COMPLETADA
  BONUS_EQUIPO
  AJUSTE_ADMIN
}

enum FuenteXP {
  APRENDIZAJE
  KPIS
  COMPROMISOS
  RECONOCIMIENTOS
  MISIONES
  EQUIPO
  SISTEMA
}

enum VisibilidadReconocimiento {
  PUBLICO
  PRIVADO
}

enum TipoMision {
  COMPLETAR_CURSO
  AVANZAR_KPI
  COMPLETAR_N_LECCIONES
  OBTENER_BADGE
  RECONOCER_PEER
  REPORTAR_KPI
  PERSONALIZADA
}

enum EstadoMision {
  ACTIVA
  COMPLETADA
  VENCIDA
  CANCELADA
}

enum EstadoCompromiso {
  PROPUESTO
  PENDIENTE
  CUMPLIDO_AUTO
  CUMPLIDO
  ATRASADO
  NO_CUMPLIDO
}

enum CriterioBadge {
  COMPLETAR_N_CURSOS
  RACHA_DIAS
  PUNTOS_ACUMULADOS
  COMPLETAR_RUTA
  PRIMER_QUIZ_PERFECTO
  COMPLETAR_N_LECCIONES
  COMPLETAR_INDUCCION
  SUBIR_A_NIVEL
}

enum PeriodoMetrica {
  MENSUAL
  TRIMESTRAL
  SEMESTRAL
  ANUAL
}

enum TipoNotificacion {
  LOGRO
  CERTIFICADO
  NUEVO_CURSO
  RECORDATORIO
  SUBIDA_NIVEL
  OBJETIVO_CUMPLIDO
  SISTEMA
  COMENTARIO_LIKE
  COMENTARIO_RESPUESTA
  COMENTARIO_REPORTADO
}

// ─── Modelos ──────────────────────────────────────────────────────────────────

model User {
  id                String     @id @default(cuid())
  email             String     @unique
  nombre            String
  apellido          String
  avatarUrl         String?
  bio               String?
  rol               RolUsuario @default(TRABAJADOR)
  puestoId          String?
  areaId            String?
  fechaIngreso      DateTime?
  nivel             Int        @default(1)
  puntosTotales     Int        @default(0)
  rachaActual       Int        @default(0)
  ultimaActividad   DateTime?
  activo            Boolean    @default(true)
  mostrarEnRanking  Boolean    @default(true)
  preferenciasEmail Json?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  puesto            Puesto?             @relation(fields: [puestoId], references: [id], onDelete: SetNull)
  area              Area?               @relation(fields: [areaId], references: [id], onDelete: SetNull)
  progresos         ProgresoLeccion[]
  intentosQuiz      IntentoQuiz[]
  badges            UserBadge[]
  transacciones     TransaccionPuntos[]
  certificados      Certificado[]
  metricas          MetricaDesempeno[]
  notificaciones    Notificacion[]
  notas             LeccionNota[]
  comentarios       Comentario[]
  comentarioLikes   ComentarioLike[]
  reportesHechos    ReporteComentario[] @relation("Reportes")
  reportesResueltos ReporteComentario[] @relation("ResolucionReportes")

  kpiAsignaciones     KpiAsignacion[]
  kpiRegistros        KpiRegistroSemanal[]
  rangosMensuales     RangoMensual[]
  eventosGamificacion EventoGamificacion[]

  hitosKpiAsignaciones KpiAsignacionMes[] @relation("HitosKpiUsuario")
  hitosKpiConfigurados KpiAsignacionMes[] @relation("HitosKpiConfigurador")
  validacionesHitosKpi KpiInstancia[]     @relation("ValidacionesHitosKpi")

  reconocimientosDados     Reconocimiento[]  @relation("ReconocimientosDados")
  reconocimientosRecibidos Reconocimiento[]  @relation("ReconocimientosRecibidos")
  misiones                 Mision[]
  compromisos              Compromiso[]
  compromisosAsignados     Compromiso[]      @relation("CompromisosAsignados")
  validacionesCompromisos  Compromiso[]      @relation("ValidacionesCompromisos")
  encuestasSemanal         EncuestaSemanal[]

  // Prompt 18 — tareas operativas estructuradas
  tareasAsignadas          TareaInstancia[]    @relation("TareasAsignadas")
  tareasEjecutadasPorAyuda TareaInstancia[]    @relation("TareasEjecutadasPorAyuda")
  tareasValidadasComoJefe  TareaInstancia[]    @relation("TareasValidadas")
  workflowsResponsable     WorkflowInstancia[] @relation("WorkflowsResponsable")

  @@index([email])
  @@index([areaId])
  @@index([puestoId])
}

model Area {
  id          String  @id @default(cuid())
  nombre      String  @unique
  descripcion String?
  color       String
  icono       String

  puestos             Puesto[]
  cursos              Curso[]
  users               User[]
  configuracionPiloto ConfiguracionPiloto?
}

model Puesto {
  id          String  @id @default(cuid())
  nombre      String
  nivel       Int
  areaId      String
  descripcion String?
  orden       Int     @default(0)

  area            Area                  @relation(fields: [areaId], references: [id], onDelete: Restrict)
  users           User[]
  rutasOrigen     RutaCarrera[]         @relation("PuestoOrigen")
  rutasDestino    RutaCarrera[]         @relation("PuestoDestino")
  kpiDefiniciones PuestoKpiDefinicion[]
  catalogoTareas  CatalogoTarea[]

  @@index([areaId])
}

model RutaCarrera {
  id              String  @id @default(cuid())
  puestoOrigenId  String
  puestoDestinoId String
  titulo          String
  descripcion     String?
  activa          Boolean @default(true)

  puestoOrigen  Puesto               @relation("PuestoOrigen", fields: [puestoOrigenId], references: [id], onDelete: Restrict)
  puestoDestino Puesto               @relation("PuestoDestino", fields: [puestoDestinoId], references: [id], onDelete: Restrict)
  cursos        RutaCarreraCurso[]
  metricas      RutaCarreraMetrica[]

  @@unique([puestoOrigenId, puestoDestinoId])
}

model RutaCarreraCurso {
  rutaCarreraId String
  cursoId       String
  requerido     Boolean @default(true)
  orden         Int

  rutaCarrera RutaCarrera @relation(fields: [rutaCarreraId], references: [id], onDelete: Cascade)
  curso       Curso       @relation(fields: [cursoId], references: [id], onDelete: Cascade)

  @@id([rutaCarreraId, cursoId])
}

model RutaCarreraMetrica {
  id            String         @id @default(cuid())
  rutaCarreraId String
  nombre        String
  descripcion   String?
  valorObjetivo Float
  unidad        String
  periodo       PeriodoMetrica

  rutaCarrera RutaCarrera @relation(fields: [rutaCarreraId], references: [id], onDelete: Cascade)
}

model Curso {
  id                  String     @id @default(cuid())
  slug                String     @unique
  titulo              String
  descripcion         String
  descripcionCorta    String?
  thumbnailUrl        String?
  duracionMinutos     Int
  nivel               NivelCurso
  areaId              String?
  publicado           Boolean    @default(false)
  puntosRecompensa    Int        @default(100)
  instructorNombre    String
  instructorAvatarUrl String?
  orden               Int        @default(0)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  area                Area?              @relation(fields: [areaId], references: [id], onDelete: SetNull)
  modulos             Modulo[]
  certificados        Certificado[]
  rutas               RutaCarreraCurso[]
  relacionadosOrigen  CursoRelacionado[] @relation("CursosRelacionadosOrigen")
  relacionadosDestino CursoRelacionado[] @relation("CursosRelacionadosDestino")
  misionesAsociadas   Mision[]

  @@index([slug])
  @@index([areaId])
  @@index([publicado])
}

model Modulo {
  id          String  @id @default(cuid())
  cursoId     String
  titulo      String
  descripcion String?
  orden       Int

  curso     Curso     @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  lecciones Leccion[]

  @@unique([cursoId, orden])
}

model Leccion {
  id                String      @id @default(cuid())
  moduloId          String
  slug              String
  titulo            String
  descripcion       String?
  tipo              TipoLeccion
  bunnyVideoId      String?
  contenidoMarkdown String?     @db.Text
  duracionSegundos  Int         @default(0)
  orden             Int
  puntosRecompensa  Int         @default(10)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  modulo      Modulo            @relation(fields: [moduloId], references: [id], onDelete: Cascade)
  quiz        Quiz?
  recursos    RecursoLeccion[]
  progresos   ProgresoLeccion[]
  notas       LeccionNota[]
  comentarios Comentario[]

  @@unique([moduloId, slug])
  @@index([moduloId])
}

model RecursoLeccion {
  id        String      @id @default(cuid())
  leccionId String
  nombre    String
  url       String
  tipo      TipoRecurso
  orden     Int

  leccion Leccion @relation(fields: [leccionId], references: [id], onDelete: Cascade)
}

model LeccionNota {
  id             String   @id @default(cuid())
  userId         String
  leccionId      String
  contenido      String   @db.Text
  timestampVideo Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  leccion Leccion @relation(fields: [leccionId], references: [id], onDelete: Cascade)

  @@index([userId, leccionId])
}

model ProgresoLeccion {
  userId           String
  leccionId        String
  completada       Boolean   @default(false)
  porcentajeVisto  Int       @default(0)
  fechaUltimaVista DateTime  @default(now())
  fechaCompletada  DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  leccion Leccion @relation(fields: [leccionId], references: [id], onDelete: Cascade)

  @@id([userId, leccionId])
  @@index([userId])
}

model Quiz {
  id            String  @id @default(cuid())
  leccionId     String  @unique
  titulo        String
  descripcion   String?
  puntajeMinimo Int     @default(70)

  leccion   Leccion       @relation(fields: [leccionId], references: [id], onDelete: Cascade)
  preguntas Pregunta[]
  intentos  IntentoQuiz[]
}

model Pregunta {
  id          String       @id @default(cuid())
  quizId      String
  texto       String       @db.Text
  tipo        TipoPregunta
  orden       Int
  explicacion String?

  quiz     Quiz              @relation(fields: [quizId], references: [id], onDelete: Cascade)
  opciones OpcionRespuesta[]
}

model OpcionRespuesta {
  id         String  @id @default(cuid())
  preguntaId String
  texto      String
  esCorrecta Boolean
  orden      Int

  pregunta Pregunta @relation(fields: [preguntaId], references: [id], onDelete: Cascade)
}

model IntentoQuiz {
  id         String   @id @default(cuid())
  userId     String
  quizId     String
  puntaje    Int
  aprobado   Boolean
  respuestas Json
  fecha      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([userId, quizId, fecha])
}

model Badge {
  id               String        @id @default(cuid())
  codigo           String        @unique
  nombre           String
  descripcion      String
  iconoUrl         String
  criterioTipo     CriterioBadge
  criterioValor    Json
  puntosRecompensa Int           @default(50)
  orden            Int           @default(0)

  usuarios UserBadge[]
}

model UserBadge {
  userId         String
  badgeId        String
  fechaObtencion DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@id([userId, badgeId])
}

model TransaccionPuntos {
  id           String      @id @default(cuid())
  userId       String
  cantidad     Int
  razon        RazonPuntos
  descripcion  String
  referenciaId String?
  fecha        DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, fecha])
}

model Certificado {
  id                 String   @id @default(cuid())
  userId             String
  cursoId            String
  codigoVerificacion String   @unique
  fechaEmision       DateTime @default(now())
  urlPdf             String?
  horasEquivalentes  Int

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  curso Curso @relation(fields: [cursoId], references: [id], onDelete: Restrict)

  @@unique([userId, cursoId])
  @@index([codigoVerificacion])
}

model MetricaDesempeno {
  id                String         @id @default(cuid())
  userId            String
  tipo              String
  nombre            String
  descripcion       String?
  valor             Float
  objetivo          Float
  unidad            String
  periodo           PeriodoMetrica
  fechaInicio       DateTime
  fechaFin          DateTime
  objetivoAlcanzado Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, periodo, fechaFin])
}

model Notificacion {
  id      String           @id @default(cuid())
  userId  String
  tipo    TipoNotificacion
  titulo  String
  mensaje String
  url     String?
  leida   Boolean          @default(false)
  fecha   DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, leida, fecha])
}

model Comentario {
  id                String    @id @default(cuid())
  userId            String
  leccionId         String
  contenido         String    @db.Text
  comentarioPadreId String?
  editado           Boolean   @default(false)
  fechaEdicion      DateTime?
  reportado         Boolean   @default(false)
  oculto            Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  leccion    Leccion             @relation(fields: [leccionId], references: [id], onDelete: Cascade)
  padre      Comentario?         @relation("Respuestas", fields: [comentarioPadreId], references: [id], onDelete: Cascade)
  respuestas Comentario[]        @relation("Respuestas")
  likes      ComentarioLike[]
  reportes   ReporteComentario[]

  @@index([leccionId, createdAt])
  @@index([userId])
  @@index([comentarioPadreId])
}

model ComentarioLike {
  userId       String
  comentarioId String
  fecha        DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  comentario Comentario @relation(fields: [comentarioId], references: [id], onDelete: Cascade)

  @@id([userId, comentarioId])
  @@index([comentarioId])
}

model ReporteComentario {
  id            String        @id @default(cuid())
  comentarioId  String
  reportadorId  String
  razon         String        @db.Text
  estado        EstadoReporte @default(PENDIENTE)
  createdAt     DateTime      @default(now())
  resueltoEn    DateTime?
  resueltoPorId String?

  comentario  Comentario @relation(fields: [comentarioId], references: [id], onDelete: Cascade)
  reportador  User       @relation("Reportes", fields: [reportadorId], references: [id])
  resueltoPor User?      @relation("ResolucionReportes", fields: [resueltoPorId], references: [id])

  @@index([estado])
  @@index([comentarioId])
}

model CursoRelacionado {
  cursoOrigenId  String
  cursoDestinoId String
  orden          Int      @default(0)
  createdAt      DateTime @default(now())

  cursoOrigen  Curso @relation("CursosRelacionadosOrigen", fields: [cursoOrigenId], references: [id], onDelete: Cascade)
  cursoDestino Curso @relation("CursosRelacionadosDestino", fields: [cursoDestinoId], references: [id], onDelete: Cascade)

  @@id([cursoOrigenId, cursoDestinoId])
  @@index([cursoOrigenId, orden])
}

model PuestoKpiDefinicion {
  id                   String         @id @default(cuid())
  puestoId             String
  codigo               String
  nombre               String
  descripcion          String         @db.Text
  // Modelo nuevo de hitos discretos validados con evidencia
  frecuencia           FrecuenciaKpi?
  puntos               Int?
  puntosMaxMes         Int?
  requiereEvidencia    Boolean        @default(true)
  esCondicional        Boolean        @default(false)
  cantidadMaxMes       Int?
  // Legacy: mediciones continuas (deprecated, mantenidos para histórico)
  unidad               String?
  peso                 Int?
  tipoMeta             TipoMetaKpi?
  valorObjetivoDefault Float?
  permiteSupera        Boolean        @default(true)
  bonusPorcentaje      Int            @default(15)
  activa               Boolean        @default(true)
  orden                Int            @default(0)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  puesto            Puesto             @relation(fields: [puestoId], references: [id], onDelete: Cascade)
  asignaciones      KpiAsignacion[]
  asignacionesMes   KpiAsignacionMes[]
  misionesAsociadas Mision[]

  @@unique([puestoId, codigo])
  @@index([puestoId])
}

model KpiAsignacionMes {
  id               String    @id @default(cuid())
  definicionId     String
  userId           String
  periodoMes       Int
  periodoAnio      Int
  noAplica         Boolean   @default(false)
  motivoNoAplica   String?
  puntosAjustados  Int?
  cantidadMes      Int?
  configuradoPorId String?
  configuradoEn    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  definicion     PuestoKpiDefinicion @relation(fields: [definicionId], references: [id], onDelete: Restrict)
  user           User                @relation("HitosKpiUsuario", fields: [userId], references: [id], onDelete: Cascade)
  configuradoPor User?               @relation("HitosKpiConfigurador", fields: [configuradoPorId], references: [id])
  instancias     KpiInstancia[]

  @@unique([definicionId, userId, periodoMes, periodoAnio])
  @@index([userId, periodoAnio, periodoMes])
}

model KpiInstancia {
  id                   String             @id @default(cuid())
  asignacionMesId      String
  semanaDelAnio        Int?
  numeroOcurrencia     Int                @default(1)
  estado               EstadoKpiInstancia @default(PENDIENTE)
  evidenciaPath        String?
  evidenciaTipo        String?
  comentarioEmpleado   String?            @db.Text
  comentarioRevisor    String?            @db.Text
  fechaReportado       DateTime?
  fechaValidado        DateTime?
  validadoPorId        String?
  puntosOtorgados      Int                @default(0)
  eventoGamificacionId String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  asignacionMes KpiAsignacionMes @relation(fields: [asignacionMesId], references: [id], onDelete: Cascade)
  validadoPor   User?            @relation("ValidacionesHitosKpi", fields: [validadoPorId], references: [id])

  @@unique([asignacionMesId, semanaDelAnio, numeroOcurrencia])
  @@index([estado])
  @@index([asignacionMesId])
}

model KpiAsignacion {
  id            String   @id @default(cuid())
  userId        String
  definicionId  String
  periodoMes    Int
  periodoAnio   Int
  valorBaseline Float?
  valorObjetivo Float
  notasInternas String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  definicion   PuestoKpiDefinicion  @relation(fields: [definicionId], references: [id], onDelete: Restrict)
  registros    KpiRegistroSemanal[]
  resultadoMes KpiResultadoMensual?

  @@unique([userId, definicionId, periodoMes, periodoAnio])
  @@index([userId, periodoMes, periodoAnio])
}

model KpiRegistroSemanal {
  id             String   @id @default(cuid())
  asignacionId   String
  semanaDelAnio  Int
  anio           Int
  valor          Float
  comentario     String?  @db.Text
  reportadoPorId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  asignacion   KpiAsignacion @relation(fields: [asignacionId], references: [id], onDelete: Cascade)
  reportadoPor User          @relation(fields: [reportadoPorId], references: [id])

  @@unique([asignacionId, semanaDelAnio, anio])
  @@index([asignacionId])
}

model KpiResultadoMensual {
  id                     String   @id @default(cuid())
  asignacionId           String   @unique
  valorConsolidado       Float
  porcentajeCumplimiento Float
  superoMeta             Boolean  @default(false)
  puntosOtorgados        Int
  incluyeBonus           Boolean  @default(false)
  calculadoEn            DateTime @default(now())

  asignacion KpiAsignacion @relation(fields: [asignacionId], references: [id], onDelete: Cascade)
}

model RangoMensual {
  id                    String    @id @default(cuid())
  userId                String
  periodoMes            Int
  periodoAnio           Int
  puntosTotales         Int
  puntosKpis            Int       @default(0)
  puntosCursos          Int       @default(0)
  puntosCompromisos     Int       @default(0)
  puntosReconocimientos Int       @default(0)
  puntosMisiones        Int       @default(0)
  cumplimientoKpis      Float     @default(0)
  multiplicadorAplicado Boolean   @default(false)
  rango                 TipoRango
  calculadoEn           DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, periodoMes, periodoAnio])
  @@index([userId, periodoAnio, periodoMes])
}

model EventoGamificacion {
  id            String                 @id @default(cuid())
  userId        String
  tipo          TipoEventoGamificacion
  fuente        FuenteXP
  cantidad      Int
  cantidadBruta Int
  metadatos     Json?
  referenciaId  String?
  mesPeriodo    Int?
  anioPeriodo   Int?
  createdAt     DateTime               @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, anioPeriodo, mesPeriodo])
  @@index([tipo])
  @@index([fuente])
}

model CategoriaReconocimiento {
  id              String           @id @default(cuid())
  codigo          String           @unique
  nombre          String
  descripcion     String
  emoji           String?
  color           String
  activa          Boolean          @default(true)
  orden           Int              @default(0)
  reconocimientos Reconocimiento[]
}

model Reconocimiento {
  id              String                    @id @default(cuid())
  nominadorId     String
  reconocidoId    String
  categoriaId     String
  mensaje         String                    @db.Text
  semanaDelAnio   Int
  anio            Int
  puntosOtorgados Int                       @default(30)
  visibilidad     VisibilidadReconocimiento @default(PUBLICO)
  createdAt       DateTime                  @default(now())

  nominador  User                    @relation("ReconocimientosDados", fields: [nominadorId], references: [id], onDelete: Cascade)
  reconocido User                    @relation("ReconocimientosRecibidos", fields: [reconocidoId], references: [id], onDelete: Cascade)
  categoria  CategoriaReconocimiento @relation(fields: [categoriaId], references: [id], onDelete: Restrict)

  @@index([reconocidoId, anio, semanaDelAnio])
  @@index([nominadorId, anio, semanaDelAnio])
}

model Mision {
  id               String       @id @default(cuid())
  userId           String
  titulo           String
  descripcion      String       @db.Text
  tipo             TipoMision
  semanaDelAnio    Int
  anio             Int
  puntosRecompensa Int          @default(30)
  metaValor        Int?
  progresoActual   Int          @default(0)
  cursoId          String?
  kpiDefinicionId  String?
  estado           EstadoMision @default(ACTIVA)
  completadaEn     DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  curso         Curso?               @relation(fields: [cursoId], references: [id], onDelete: SetNull)
  kpiDefinicion PuestoKpiDefinicion? @relation(fields: [kpiDefinicionId], references: [id], onDelete: SetNull)

  @@index([userId, anio, semanaDelAnio, estado])
}

model Compromiso {
  id                    String           @id @default(cuid())
  userId                String
  asignadoPorId         String?
  titulo                String
  descripcion           String?          @db.Text
  fechaLimite           DateTime
  fechaCumplimiento     DateTime?
  semanaDelAnio         Int
  anio                  Int
  estado                EstadoCompromiso @default(PENDIENTE)
  autoReportadoCumplido Boolean          @default(false)
  validadoPorId         String?
  validadoEn            DateTime?
  validacionComentario  String?          @db.Text
  puntosOtorgados       Int              @default(0)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  user        User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  asignadoPor User? @relation("CompromisosAsignados", fields: [asignadoPorId], references: [id])
  validadoPor User? @relation("ValidacionesCompromisos", fields: [validadoPorId], references: [id])

  @@index([userId, estado])
  @@index([userId, anio, semanaDelAnio])
  @@index([fechaLimite])
}

model ConfiguracionPiloto {
  id                    String    @id @default(cuid())
  areaId                String    @unique
  activo                Boolean   @default(true)
  fechaInicio           DateTime
  fechaFin              DateTime
  metaCumplimientoKpis  Float     @default(80)
  bonusEquipoPuntos     Int       @default(150)
  bonusYaOtorgadoMes    Int?
  bonusYaOtorgadoAnio   Int?
  anonimizarParaJefe    Boolean   @default(true)
  fechaFinAnonimizacion DateTime?
  mostrarBannerPiloto   Boolean   @default(true)
  fechaFinBanner        DateTime?
  notas                 String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  area Area @relation(fields: [areaId], references: [id], onDelete: Cascade)
}

model EncuestaSemanal {
  id                String   @id @default(cuid())
  userId            String
  semanaDelAnio     Int
  anio              Int
  justiciaKpis      Int
  motivacionSistema Int
  claridadProgreso  Int
  comentario        String?  @db.Text
  kpiMasJusto       String?
  kpiMenosJusto     String?
  puntosOtorgados   Int      @default(20)
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, semanaDelAnio, anio])
  @@index([anio, semanaDelAnio])
}

// ═══════════════════════════════════════════════════════════════════
// Prompt 18 — Tareas operativas estructuradas (workflows + checklist)
// Los puntos pasan por procesarEvento (fuente COMPROMISOS, tope 200/mes)
// ═══════════════════════════════════════════════════════════════════

enum CategoriaTarea {
  PRE_WEBINAR
  DURANTE_WEBINAR
  POST_WEBINAR
  SEO_RECURRENTE
  CAMPANA_META_ADS
  COORDINACION_GENERAL
  DISENO
  DESARROLLO_WEB
}

enum TipoTrabajoTarea {
  COORDINACION
  EJECUCION
  ANALISIS
  REVISION
}

enum TipoDependencia {
  FIN_A_INICIO
  FIN_A_FIN
  INICIO_A_INICIO
}

enum CategoriaWorkflow {
  WEBINAR
  CAMPANA_MARKETING
  LANZAMIENTO_CURSO
  EVENTO_PRESENCIAL
}

enum EstadoWorkflow {
  ACTIVO
  COMPLETADO
  CANCELADO
  PAUSADO
}

enum EstadoTareaInstancia {
  PENDIENTE
  BLOQUEADA
  EN_PROGRESO
  EN_REVISION
  COMPLETADA
  OMITIDA
  VENCIDA
}

enum OrigenTarea {
  AUTO_WORKFLOW   // generada al crear workflow
  ASIGNADA_JEFE   // asignada directamente por el jefe (con o sin workflow)
  AUTO_ASIGNADA   // el empleado la creó por su cuenta (requiere validación)
}

model CatalogoTarea {
  id                  String           @id @default(cuid())
  codigo              String           @unique
  nombre              String
  descripcion         String           @db.Text
  categoria           CategoriaTarea
  rolResponsableId    String
  tiempoMinimoMin     Int
  tiempoMaximoMin     Int
  tipoTrabajo         TipoTrabajoTarea
  puntosBase          Int              @default(5)
  bonusATiempo        Int              @default(2)
  bonusDesbloqueo     Int              @default(3)
  permiteVariabilidad Boolean          @default(true)
  activa              Boolean          @default(true)
  orden               Int              @default(0)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  rolResponsable      Puesto                   @relation(fields: [rolResponsableId], references: [id], onDelete: Restrict)
  checklistItems      ChecklistItemPlantilla[]
  dependenciasOrigen  DependenciaTarea[]       @relation("TareaOrigen")
  dependenciasDestino DependenciaTarea[]       @relation("TareaDestino")
  instancias          TareaInstancia[]
  enWorkflows         TareaEnWorkflow[]

  @@index([categoria, activa])
  @@index([rolResponsableId])
}

model ChecklistItemPlantilla {
  id                String  @id @default(cuid())
  catalogoTareaId   String
  orden             Int
  descripcion       String  @db.Text
  ayudaContextual   String? @db.Text
  obligatorio       Boolean @default(true)
  tiempoEstimadoMin Int?

  catalogoTarea CatalogoTarea          @relation(fields: [catalogoTareaId], references: [id], onDelete: Cascade)
  marcados      ChecklistItemMarcado[]

  @@index([catalogoTareaId, orden])
}

model DependenciaTarea {
  id              String          @id @default(cuid())
  tareaOrigenId   String
  tareaDestinoId  String
  tipoDependencia TipoDependencia @default(FIN_A_INICIO)
  holguraDias     Int             @default(0)

  tareaOrigen  CatalogoTarea @relation("TareaOrigen", fields: [tareaOrigenId], references: [id], onDelete: Cascade)
  tareaDestino CatalogoTarea @relation("TareaDestino", fields: [tareaDestinoId], references: [id], onDelete: Cascade)

  @@unique([tareaOrigenId, tareaDestinoId])
}

model WorkflowPlantilla {
  id                String            @id @default(cuid())
  codigo            String            @unique
  nombre            String
  descripcion       String            @db.Text
  categoria         CategoriaWorkflow
  duracionTotalDias Int
  activo            Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  tareas     TareaEnWorkflow[]
  instancias WorkflowInstancia[]
}

model TareaEnWorkflow {
  id               String  @id @default(cuid())
  workflowId       String
  catalogoTareaId  String
  ordenEjecucion   Int
  diasAntesDelHito Int
  obligatoria      Boolean @default(true)

  workflow      WorkflowPlantilla @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  catalogoTarea CatalogoTarea     @relation(fields: [catalogoTareaId], references: [id], onDelete: Cascade)

  @@unique([workflowId, catalogoTareaId])
  @@index([workflowId, ordenEjecucion])
}

model WorkflowInstancia {
  id                   String         @id @default(cuid())
  plantillaId          String
  nombre               String
  contextoMarca        String?
  fechaHito            DateTime
  estadoGeneral        EstadoWorkflow @default(ACTIVO)
  responsableGeneralId String
  notas                String?        @db.Text
  createdAt            DateTime       @default(now())
  actualizadoEn        DateTime       @updatedAt

  plantilla          WorkflowPlantilla @relation(fields: [plantillaId], references: [id], onDelete: Restrict)
  responsableGeneral User              @relation("WorkflowsResponsable", fields: [responsableGeneralId], references: [id], onDelete: Restrict)
  tareas             TareaInstancia[]

  @@index([fechaHito, estadoGeneral])
  @@index([responsableGeneralId])
}

model TareaInstancia {
  id                        String               @id @default(cuid())
  workflowInstanciaId       String?              // opcional para tareas ad-hoc
  catalogoTareaId           String?              // opcional para tareas ad-hoc
  asignadoAId               String
  origen                    OrigenTarea          @default(AUTO_WORKFLOW)
  estado                    EstadoTareaInstancia @default(PENDIENTE)

  // Datos ad-hoc (cuando no hay catálogo)
  nombreAdHoc               String?
  descripcionAdHoc          String?              @db.Text
  puntosBaseAdHoc           Int?
  tiempoEstimadoMinAdHoc    Int?
  tiempoEstimadoMaxAdHoc    Int?

  fechaEstimadaInicio       DateTime
  fechaEstimadaFin          DateTime
  fechaInicioReal           DateTime?
  fechaFinReal              DateTime?
  tiempoInvertidoMin        Int?
  bloqueadoPor              String?
  bloqueoExternoDesde       DateTime?
  bloqueoExternoHasta       DateTime?
  bloqueoExternoResponsable String?
  bloqueoExternoMotivo      String?              @db.Text
  completadaEn              DateTime?
  calidadAutoeval           Int?
  notasEjecutor             String?              @db.Text
  ejecutadaPorOtro          Boolean              @default(false)
  ejecutadaRealmenteId      String?
  motivoAyuda               String?

  // Validación del jefe (para ad-hoc del empleado)
  requiereValidacionJefe    Boolean              @default(false)
  validadaPorJefeId         String?
  validadaEn                DateTime?
  comentarioValidacion      String?              @db.Text

  // Puntos — brutos y prorrateados
  puntosBrutos              Int                  @default(0)
  puntosOtorgados           Int                  @default(0)
  puntosATiempo             Boolean              @default(false)
  puntosDesbloqueo          Boolean              @default(false)
  factorProrrateo           Float                @default(1.0)

  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt

  workflowInstancia  WorkflowInstancia?     @relation(fields: [workflowInstanciaId], references: [id], onDelete: Cascade)
  catalogoTarea      CatalogoTarea?         @relation(fields: [catalogoTareaId], references: [id], onDelete: Restrict)
  asignadoA          User                   @relation("TareasAsignadas", fields: [asignadoAId], references: [id], onDelete: Restrict)
  ejecutadaRealmente User?                  @relation("TareasEjecutadasPorAyuda", fields: [ejecutadaRealmenteId], references: [id], onDelete: SetNull)
  validadaPorJefe    User?                  @relation("TareasValidadas", fields: [validadaPorJefeId], references: [id], onDelete: SetNull)
  checklistMarcados  ChecklistItemMarcado[]

  @@index([asignadoAId, estado])
  @@index([workflowInstanciaId, estado])
  @@index([fechaEstimadaFin, estado])
  @@index([asignadoAId, origen, requiereValidacionJefe])
}

model ChecklistItemMarcado {
  id               String    @id @default(cuid())
  tareaInstanciaId String
  plantillaItemId  String
  marcado          Boolean   @default(false)
  marcadoEn        DateTime?
  notaRapida       String?

  tareaInstancia TareaInstancia         @relation(fields: [tareaInstanciaId], references: [id], onDelete: Cascade)
  plantillaItem  ChecklistItemPlantilla @relation(fields: [plantillaItemId], references: [id], onDelete: Cascade)

  @@unique([tareaInstanciaId, plantillaItemId])
}
